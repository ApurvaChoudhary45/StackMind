{
  "name": "stackmind-vscode",
  "displayName": "stackmind-vscode",
  "description": "Save snippets and ask AI from VS code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stackmind.saveSnippet",
        "title": "StackMind: Save as Snippet"
      },
      {
        "command": "stackmind.askAI",
        "title": "StackMind: Ask AI"
      },
      {
        "command": "stackmind.connect",
        "title": "StackMind: Connect Account"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "stackmind.saveSnippet",
          "when": "editorHasSelection",
          "group": "stackmind@1"
        },
        {
          "command": "stackmind.askAI",
          "when": "editorHasSelection",
          "group": "stackmind@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}